---
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Property Management",
    description: "Comprehensive management services to ensure your commercial properties operate smoothly and efficiently.",
    icon: "tabler:building",
  },
  {
    title: "Brokerage",
    description: "Connecting you with the perfect commercial properties to meet your business needs.",
    icon: "tabler:key",
  },
  {
    title: "Asset Management",
    description: "Maximizing the value and performance of your real estate investments.",
    icon: "tabler:heart-handshake",
  },
];
---

<section class="relative flex w-full flex-col items-center pt-16 pb-20 text-center">
  <div class="max-w-3xl">
    <h2 data-animate class="mb-4 text-sm font-bold">Services</h2>
    <h3 data-animate data-delay="0.04" class="font-fraunces text-center text-4xl text-balance md:text-5xl">
      What we do for your business
    </h3>
    <p data-animate data-delay="0.08" class="mt-4 text-sm text-pretty md:text-base">
      We handle the details so you can focus on what matters. From finding the right space to managing day-to-day
      operations, we're here.
    </p>
  </div>

  <div class="mt-8 flex flex-wrap items-start justify-center gap-x-8">
    {
      services.map((service, i) => (
        <div
          data-animate
          data-delay={0.48 + i * 0.06}
          class="mt-8 flex w-full flex-col items-center sm:w-[48%] lg:w-[30%]"
        >
          <div class="text-brand-gold text-4xl">
            <Icon name={service.icon} />
          </div>
          <h3 class="font-fraunces mt-5 text-3xl">{service.title}</h3>
          <p class="mt-4 text-sm text-pretty">{service.description}</p>
        </div>
      ))
    }
  </div>
</section>
