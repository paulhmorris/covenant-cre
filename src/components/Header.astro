---
import { Icon } from "astro-icon/components";
---

<header
  class="fixed top-0 right-0 left-0 z-50 flex h-24 shrink-0 items-center justify-center bg-white/80 p-7 backdrop-blur-md sm:h-40 sm:px-14"
>
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between">
    <div>
      <a href="/">
        <span class="sr-only">Home</span>
        <img src="/logo-full.svg" alt="Covenant Commercial Real Estate Logo" class="size-20 sm:size-48" />
      </a>
    </div>
    <div>
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-brand-blue border-brand-blue/50 hover:bg-brand-blue/85 inline-flex items-center justify-center gap-x-2.5 rounded-lg border px-4 py-2 text-sm tracking-wide text-white"
      >
        <span>Client Login</span>
        <Icon name="tabler:external-link" />
      </a>
    </div>
  </div>
</header>
