---
import "@fontsource-variable/figtree";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../global.css";

type Props = {
  headerBgColor: "bg-transparent" | "bg-gray-600";
};
const { headerBgColor = "bg-transparent" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Covenant CRE provides commercial real estate services in Rockwall, TX and surrounding areas."
    />

    <meta property="og:site_name" content="Covenant Commercial Real Estate" />
    <meta property="og:title" content="Covenant Commercial Real Estate" />
    <meta property="og:url" content="https://www.covenantcre.com" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta
      property="og:description"
      content="Covenant CRE provides commercial real estate services in Rockwall, TX and surrounding areas."
    />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={Astro.url.toString()} />
    <slot name="meta" />
    <!-- <Analytics /> -->
  </head>

  <body class="flex h-full min-h-screen flex-col text-gray-600">
    <Header />
    <main class="h-full grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
