---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../global.css";
import Analytics from "../components/Analytics.astro";
---

<!doctype html>
<html lang="en" class="min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Covenant CRE provides commercial real estate services in Rockwall, TX and surrounding areas."
    />

    <meta name="robots" content="noindex" />
    <meta property="og:site_name" content="Covenant Commercial Real Estate" />
    <meta property="og:title" content="Covenant Commercial Real Estate" />
    <meta property="og:url" content="https://www.covenantcre.com" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.png" />
    <meta
      property="og:description"
      content="Covenant CRE provides commercial real estate services in Rockwall, TX and surrounding areas."
    />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={Astro.url.toString()} />
    <slot name="meta" />
    <Analytics />
    <script>
      import { animate } from "motion";
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      document.addEventListener("DOMContentLoaded", () => {
        const els = Array.from(document.querySelectorAll("[data-animate]"));

        if (prefersReduced) {
          els.forEach((el) => {
            if (el instanceof HTMLElement) {
              el.style.opacity = "1";
              el.style.transform = "none";
            }
          });
          return;
        }

        // set initial hidden state
        els.forEach((el) => {
          if (el instanceof HTMLElement) {
            el.style.opacity = "0";
            el.style.transform = "translateY(8px)";
          }
        });

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delayAttr = el.getAttribute("data-delay");
              const delay = delayAttr ? parseFloat(delayAttr) : 0;
              animate(
                el,
                { opacity: [0, 1], transform: ["translateY(8px)", "translateY(0px)"] },
                { duration: 0.6, easing: "cubic-bezier(.2,.8,.2,1)", delay }
              );
              obs.unobserve(el);
            });
          },
          { threshold: 0.12 }
        );

        els.forEach((el, i) => {
          if (!el.hasAttribute("data-delay")) {
            el.setAttribute("data-delay", String(i * 0.06));
          }
          observer.observe(el);
        });
      });
    </script>
  </head>

  <body class="flex min-h-screen flex-col text-gray-800">
    <Header />
    <main class="mt-24 grow sm:mt-40">
      <slot />
    </main>
    <Footer />
  </body>
</html>
